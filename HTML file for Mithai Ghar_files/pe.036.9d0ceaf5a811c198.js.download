u:"Сдвиньте для проверки",ms:"Sila leret untuk mengesahkan",th:"กรุณาเลื่อนเพื่อยืนยัน",tr:"Doğrulamak i\xe7in l\xfctfen kaydırın",vi:"Vui l\xf2ng trượt để x\xe1c minh"}},{text:"请先完成验证！",key:"FINISH_CAPTCHA",value:{cn:"请先完成验证！",tw:"請先完成驗證！",en:"Please complete captcha first",ar:"يرجى إكمال التحقق أولا",de:"Bitte f\xfcllen Sie zuerst das Captcha aus",es:"Complete el captcha primero",fr:"Veuillez d'abord compl\xe9ter le captcha",in:"Selesaikan captcha terlebih dahulu",it:"Completa prima il captcha",ja:"最初にキャプチャを完了して下さい",ko:"먼저 captcha를 완료하세요",pt:"Por favor, preencha primeiro o captcha",ru:"Сначала введите капчу",ms:"Sila lengkapkan captcha dahulu",th:"กรุณากรอกรหัสยืนยันก่อน",tr:"L\xfctfen \xf6nce captcha'yı tamamlayın",vi:"Vui l\xf2ng ho\xe0n th\xe0nh captcha trước"}},{text:"验证中...",key:"VERIFYING",value:{cn:"验证中...",tw:"驗證中...",en:"Verifying...",ar:"التحقق",de:"Verifizieren...",es:"Verificando...",fr:"V\xe9rification...",in:"Memverifikasi...",it:"Verificando...",ja:"検証中です",ko:"확인 중...",pt:"Verificar...",ru:"Проверка...",ms:"Mengesahkan...",th:"กำลังยืนยัน...",tr:"Doğrulanıyor...",vi:"Đang x\xe1c minh..."}},{text:"滑动完成",key:"CAPTCHA_COMPLETED",value:{cn:"滑动完成",tw:"滑動完成",en:"Sliding completed",ar:"اكتمل التمرير",de:"Schieben abgeschlossen",es:"Deslizamiento completado",fr:"Glissement termin\xe9",in:"Geser selesai",it:"Scorrimento completato",ja:"スライド完了",ko:"슬라이딩 완료",pt:"Deslizamento conclu\xeddo",ru:"Завершено",ms:"Leret selesai",th:"เลื่อนเสร็จ",tr:"Kaydırma tamamlandı",vi:"Đ\xe3 ho\xe0n th\xe0nh trượt"}},{text:"验证通过!",key:"SUCCESS",value:{cn:"验证通过!",tw:"驗證通過！",en:"Verified",ar:"محقق",de:"Verifiziert",es:"Verificado",fr:"V\xe9rifi\xe9",in:"Terverifikasi",it:"Verificato",ja:"検証済み",ko:"인증됨",pt:"Verificado",ru:"Проверка завершена",th:"ยืนยันเสร็จสิ้น",ms:"Disahkan",tr:"Doğrulandı",vi:"Đ\xe3 x\xe1c minh"}},{text:"验证失败，请刷新",key:"SLIDE_FAIL",value:{cn:"验证失败，请刷新",tw:"驗證失敗，請重新整理",en:"Verification failed. Refresh to retry.",ar:"فشل التحقق. يُرجى التحديث.",de:"Verifizierung fehlgeschlagen. Aktualisieren.",es:"Verificaci\xf3n fallida. Actualice.",fr:"\xc9chec de la v\xe9rification. Veuillez actualiser.",in:"Verifikasi gagal. Muat ulang.",it:"Verifica fallita. Aggiorna.",ja:"認証に失敗しました。更新してください。",ko:"인증 실패. 새로 고침하세요.",pt:"Falha na verifica\xe7\xe3o. Atualize.",ru:"Ошибка проверки. Обновите страницу.",ms:"Pengesahan gagal. Muat semula.",th:"ยืนยันไม่สำเร็จ กรุณาโหลดใหม่",tr:"Doğrulama başarısız. Yenileyin.",vi:"X\xe1c minh thất bại. Tải lại."}},{text:"验证失败，请重试",key:"CAPTCHA_FAIL",value:{cn:"验证失败，请重试",tw:"驗證失敗，請重試",en:"Verification failed. Try again.",ar:"فشل التحقق. أعد المحاولة.",de:"Fehlgeschlagen. Bitte erneut versuchen.",es:"Error. Int\xe9ntalo de nuevo.",fr:"\xc9chec. R\xe9essayez.",in:"Gagal. Coba lagi.",it:"Fallito. Riprova.",ja:"認証に失敗しました。再試行してください。",ko:"인증 실패. 다시 시도하세요.",pt:"Falha. Tente novamente.",ru:"Ошибка. Повторите попытку.",ms:"Gagal. Cuba lagi.",th:"ยืนยันไม่สำเร็จ ลองอีกครั้ง",tr:"Başarısız. Tekrar deneyin.",vi:"Thất bại. Thử lại."}},{text:"加载中...",key:"LOADING",value:{cn:"加载中...",tw:"加載中...",en:"Loading...",ar:"تحميل",de:"Laden…",es:"Cargando",fr:"Chargement...",in:"Memuat...",it:"Caricando...",ja:"読み込み中です",ko:"로드 중...",pt:"Carregando...",ru:"Загрузка…",ms:"Memuatkan...",th:"กำลังโหลด...",tr:"Y\xfckleniyor...",vi:"Đang tải..."}},{text:"拖动滑块完成拼图",key:"PUZZLE_TIP",value:{cn:"拖动滑块完成拼图",tw:"拖動滑塊完成拼圖",en:"Drag to complete the puzzle",ar:"اسحب لإكمال اللغز",de:"Ziehen, um das Puzzle zu l\xf6sen",es:"Arrastra para completar el puzle",fr:"Glissez pour compl\xe9ter le puzzle",in:"Seret untuk menyelesaikan teka-teki",it:"Trascina per completare il puzzle",ja:"ドラッグしてパズルを完成",ko:"퍼즐을 완성하려면 드래그하세요",pt:"Arraste para completar o quebra-cabe\xe7a",ru:"Перетащите, чтобы собрать пазл",ms:"Seret untuk melengkapkan teka-teki",th:"ลากเพื่อเติมภาพให้สมบูรณ์",tr:"Bulmacayı tamamlamak i\xe7in s\xfcr\xfckle",vi:"K\xe9o để ho\xe0n th\xe0nh h\xecnh gh\xe9p"}},{text:"拖动滑块还原图片",key:"INPAINTING_TIP",value:{cn:"拖动滑块还原图片",tw:"拖曳滑桿還原圖片",en:"Drag to complet